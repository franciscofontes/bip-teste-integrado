<persistence xmlns="https://jakarta.ee"
             xmlns:xsi="http://www.w3.org"
             xsi:schemaLocation="https://jakarta.ee https://jakarta.ee/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="h2-unit" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <properties>
            <!-- Configs do banco H2 -->
            <property name="javax.persistence.jdbc.driver" value="org.h2.Driver" />
            <property name="javax.persistence.jdbc.url" value="jdbc:h2:mem:testdb" />
            <property name="javax.persistence.jdbc.user" value="sa" />
            <property name="javax.persistence.jdbc.password" value="" />

            <!-- Hibernate dialect para H2 -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect" />

            <!-- Criando automaticamente -->
            <property name="javax.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="javax.persistence.schema-generation.create-script-source" value="../../../../../db/schema.sql" />
            <property name="javax.persistence.sql-load-script-source" value="../../../../../db/seed.sql" />
        </properties>
    </persistence-unit>
</persistence>
